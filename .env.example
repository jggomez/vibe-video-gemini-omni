# Environment Variables — Vibe Video Multi-Agent Studio

# ── Gemini API ──────────────────────────────────────────────────────────────
# Required: your Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GOOGLE_API_KEY=your-gemini-api-key-here  # alias used by google-adk

# ── Vertex AI (production, optional) ───────────────────────────────────────
# Uncomment to use Vertex AI instead of AI Studio
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_GENAI_USE_VERTEXAI=True

# ── Session Storage (optional) ─────────────────────────────────────────────
# Leave empty to use InMemorySessionService (default for local dev)
# SESSION_SERVICE_URI=sqlite:///./vibe_sessions.db

# ── Artifact Storage (optional) ────────────────────────────────────────────
# Leave empty to use InMemoryArtifactService (default for local dev)
# LOGS_BUCKET_NAME=your-gcs-bucket

# ── Server Config ───────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ALLOW_ORIGINS=http://localhost:3000,http://localhost:8000
